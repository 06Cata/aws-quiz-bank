{
  "name": "aws-quiz-bank",
  "private": true,
  "workspaces": [
    "apps/web"
  ],
  "scripts": {
    "dev:web": "npm --workspace apps/web run dev",
    "build:web": "npm --workspace apps/web run build",
    "lint:web": "npm --workspace apps/web run lint",
    "dev:api": "cd apps/api && uvicorn app.main:app --reload --host 0.0.0.0 --port 8000",
    "sync:questions": "cd apps/api && python -m app.jobs.sync_local_questions --exam saa",
    "sync:questions:saa": "cd apps/api && python -m app.jobs.sync_local_questions --exam saa",
    "sync:questions:clf": "cd apps/api && python -m app.jobs.sync_local_questions --exam clf",
    "sync:flashcards:saa": "cd apps/api && python -m app.jobs.sync_local_flashcards --exam saa",
    "sync:flashcards:clf": "cd apps/api && python -m app.jobs.sync_local_flashcards --exam clf",
    "validate:questions": "cd apps/api && python -m app.services.local_questions ../../questions --exam saa",
    "validate:questions:saa": "cd apps/api && python -m app.services.local_questions ../../questions --exam saa",
    "validate:questions:clf": "cd apps/api && python -m app.services.local_questions ../../questions --exam clf",
    "validate:flashcards:saa": "cd apps/api && python -m app.jobs.sync_local_flashcards --exam saa --validate-only",
    "validate:flashcards:clf": "cd apps/api && python -m app.jobs.sync_local_flashcards --exam clf --validate-only"
  }
}
